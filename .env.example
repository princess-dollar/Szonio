LLM_GATEWAY_API_KEY=sk-...            # bearer key for the internal LLM Gateway
LLM_GATEWAY_BASE_URL=https://...      # gateway base URL, no trailing /v1
LLM_GATEWAY_TIMEOUT_SECONDS=60        # request timeout (optional, default 60)
LLM_GATEWAY_MODEL=openai/gpt-4.1-mini # model string (optional, default openai/gpt-4.1-mini)
